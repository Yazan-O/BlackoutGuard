# COMMIT these (do NOT ignore) — needed for a fresh clone to run the demo:
#   contracts/fixtures/*.json   (baked detections)
#   voice/cache/*.wav           (pre-rendered demo advisories — small, so offline demo runs on clone)
#   app/public/clips/*.mp4      (compressed demo clips; keep each < 100 MB — GitHub cap; ffmpeg or Git LFS if larger)

# Internal dev-log reports — not part of the submission; keep box names/paths out of the public repo
reports/

# Full-res event bins (WebGPU tier) — 45MB each, local-only; ship the ~4MB downsampled tier
app/public/clips/*.events.full.bin
