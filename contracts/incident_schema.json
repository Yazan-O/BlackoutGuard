{ "$schema":"http://json-schema.org/draft-07/schema#","title":"BlackoutGuardIncident","type":"object",
  "required":["incident_id","clip_id","t_video_s","frame_idx","detections","rgb_blind","blindness_duration_s","severity"],
  "properties":{
    "incident_id":{"type":"string"},"clip_id":{"type":"string"},"t_utc":{"type":["string","null"]},
    "t_video_s":{"type":"number"},"frame_idx":{"type":"integer"},
    "detections":{"type":"array","items":{"type":"object","required":["class_name","confidence","bbox"],
      "properties":{"class_name":{"type":"string","enum":["pedestrian","rider","bicycle","car","bus","truck","motorcycle","train"]},
        "confidence":{"type":"number"},"bbox":{"type":"array","items":{"type":"number"},"minItems":4,"maxItems":4},
        "track_id":{"type":["integer","null"]}}}},
    "rgb_blind":{"type":"boolean"},"blindness_duration_s":{"type":"number"},
    "gps":{"type":["array","null"],"items":{"type":"number"}},
    "severity":{"type":"string","enum":["info","caution","brake"]},
    "advisory":{"type":["string","null"]},
    "operator_action":{"type":["object","null"]}}}
